@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section ToolBar {
    <div class="toolbar py-2" id="kt_toolbar">
        <!--begin::Container-->
        <div id="kt_toolbar_container" class=" container-fluid  d-flex align-items-center">
            <div data-kt-swapper="true" data-kt-swapper-mode="prepend" data-kt-swapper-parent="{default: '#kt_content_container', 'lg': '#kt_toolbar_container'}" class="page-title d-flex align-items-center flex-wrap me-3  mb-5 mb-lg-0 ">
                <!--begin::Title-->
                <h1 class="d-flex align-items-center text-dark fw-bold my-1 fs-3">
                    Quản lý Thiết bị
                </h1>
                <!--end::Title-->
                <!--begin::Separator-->
                <span class="h-20px border-gray-200 border-start mx-3"></span>
                <!--end::Separator-->
                <!--begin::Breadcrumb-->
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                    <!--begin::Item-->
                    <li class="breadcrumb-item text-muted">
                        <a href="/" class="text-muted text-hover-primary">
                            Trang chủ
                        </a>
                    </li>
                    <!--end::Item-->
                    <!--begin::Item-->
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-200 w-5px h-2px"></span>
                    </li>
                    <!--end::Item-->
                    <!--begin::Item-->
                    <li class="breadcrumb-item text-muted">
                        Thiết bị
                    </li>
                    <!--end::Item-->
                    <!--begin::Item-->
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-200 w-5px h-2px"></span>
                    </li>
                    <!--end::Item-->
                    <li class="breadcrumb-item">
                        Chi tiết
                    </li>

                </ul>
                <!--end::Breadcrumb-->
            </div>
            <!--begin::Page title-->
            <div class="flex-grow-1 flex-shrink-0 me-5">

                <!--begin::Page title-->
                <!--end::Page title-->
            </div>
            <!--end::Page title-->
            <!--begin::Action group-->

            <div class="d-flex align-items-center flex-wrap">
            </div>
            <!--end::Action group-->
        </div>
        <!--end::Container-->
    </div>
}

<div class="g-5 g-xl-10 ">
    <div class="content d-flex flex-column flex-column-fluid">
        <!--begin::Form-->
        <form class=" form d-flex flex-column flex-lg-row">
            <!--begin::Aside column-->
            <div class="d-flex flex-column gap-7 gap-lg-10 w-lg-300px w-100  mb-7 me-lg-10">
                <!--begin::Thumbnail settings-->
                <div class="card card-flush py-4">
                    <!--begin::Card header-->
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div class="card-title">
                            <h2 class="mb-0">Trạng thái</h2>
                        </div>

                        <div class="badge fw-bold p-3"
                             data-bind="text: $root.getLicenseStatusText(),
                                 css:  $root.getLicenseStatusClass()">
                        </div>
                    </div>
                    <!--end::Card header-->
                    <!--begin::Card body-->
                    <div class="card-body pt-0">
                        <!-- ko if: $root.selectedLicenseItem().licenseValue() -->
                        <div class="mb-5 d-flex flex-row justify-content-between">
                            <!--begin::Label-->
                            <label class="form-label">Ngày tạo</label>
                            <!--end::Label-->
                            <!--begin::Label-->
                            <label class="form-label fw-bold" data-bind="text: $root.selectedLicenseItem().createdTime()"></label>
                            <!--end::Label-->
                        </div>
                        <div class="mb-5 d-flex flex-row justify-content-between">
                            <!--begin::Label-->
                            <label class="form-label ">Ngày hết hạn</label>
                            <!--end::Label-->
                            <!--begin::Label-->
                            <label class="form-label fw-bold" data-bind="text:$root.selectedLicenseItem().expiredTime()"></label>
                            <!--end::Label-->
                        </div>
                        <!-- /ko -->
                        <!-- ko ifnot: $root.selectedLicenseItem().licenseValue() -->
                        <button type="button"
                                class="btn btn-sm btn-primary"
                                data-bind="click: function(){ $root.OpenAssignLicenseModal() }">
                            Gán license
                        </button>
                        <!-- /ko -->
                      
                    </div>
                    <!--end::Card body-->
                </div>
                <!--end::Thumbnail settings-->

            </div>
            <!--end::Aside column-->
            <!--begin::Main column-->
            <div class="d-flex flex-column flex-row-fluid gap-7 gap-lg-10">
                <div class="d-flex flex-column gap-7 gap-lg-10">
                    <div class="card card-flush py-4">
                        <!--begin::Card header-->
                        <div class="card-header">
                            <div class="card-title">
                                <h2>Thiết bị</h2>
                            </div>
                            <!--begin:::Actions-->
                            <div class="justify-content-end align-content-center">
                                <!--begin::Button-->
                                <a class="btn btn-danger me-1" data-bind="click: function(){ $root.DeleteDevice() }">Xóa</a>
                                <!--end::Button-->
                                <!--begin::Button-->
                                <button type="submit" class="btn btn-primary">
                                    <span class="indicator-label" data-bind="click: function(){ $root.UpdateDevice() }">Cập nhật</span>
                                </button>
                                <!--end::Button-->
                            </div>
                            <!--end:::Actions-->
                        </div>
                        <!--end::Card header-->
                        <!--begin::Card body-->
                        <div class="card-body pt-0">
                            <!--begin::Input group-->
                            <div class="mb-5 fv-row fv-plugins-icon-container">
                                <!--begin::Label-->
                                <label class="required form-label">Tên</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" class="form-control mb-2" placeholder="Tên thiết bị" data-bind="value: $root.selectedDeviceItem().deviceName">
                                <!--end::Input-->
                                <!--end::Input group-->
                            </div>
                            <!--begin::Input group-->
                            <div class="mb-5 fv-row fv-plugins-icon-container">
                                <!--begin::Label-->
                                <label class="required form-label">ChipsetId</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" class="form-control mb-2" placeholder="ChipsetId"
                                       data-bind="value: $root.selectedDeviceItem().chipsetID,
                                      disable: ($root.selectedLicenseItem() && $root.selectedLicenseItem().licenseValue && $root.selectedLicenseItem().licenseValue())">

                                <!--end::Input-->
                                <!--end::Input group-->
                            </div>
                            <!--begin::Input group-->
                            <div class="mb-5 fv-row fv-plugins-icon-container">
                                <label class="required form-label">Ghi chú</label>

                                <textarea class="form-control mb-2"
                                          placeholder="Ghi chú..."
                                          data-bind="value: $root.selectedDeviceItem().note"></textarea>
                            </div>
                        </div>
                        <!--end::General options-->
                    </div>

                    <!-- ko if: $root.selectedLicenseItem().licenseValue() -->
                    <div class="card card-flush py-4">
                        <!--begin::Card header-->
                        <div class="card-header">
                            <div class="card-title">
                                <h2>License</h2>
                            </div>
                            <!--begin:::Actions-->
                            <div class="justify-content-end align-content-center">
                                <!--begin::Button-->
                                <a class="btn btn-secondary me-1" data-bind="click: function(){ $root.RevokeLicense() }">Thu hồi</a>
                                <!--end::Button-->
                                <!--begin::Button-->
                                <a class="btn btn-danger me-1" data-bind="click: function(){ $root.DeleteLicense() }">Xóa</a>
                                <!--end::Button-->
                                <!--begin::Button-->
                                <button type="submit" class="btn btn-primary" data-bind="click: function(){ $root.UpdateLicense() }">
                                    <span class="indicator-label">Cập nhật</span>
                                </button>
                                <!--end::Button-->
                            </div>
                            <!--end:::Actions-->
                        </div>
                        <!--end::Card header-->
                        <!--begin::Card body-->
                        <div class="card-body pt-0">
                            <!--begin::Input group-->
                            <div class="mb-5 fv-row fv-plugins-icon-container">
                                <!--begin::Label-->
                                <label class="required form-label">Name</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" class="form-control mb-2" placeholder="License name" data-bind="value: $root.selectedLicenseItem().licenseName">
                                <!--end::Input-->
                                <!--end::Input group-->
                            </div>
                            <!--begin::Input group-->
                            <div class="mb-5 fv-row fv-plugins-icon-container">
                                <!--begin::Label-->
                                <label class="required form-label">Value</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <textarea type="text" class="form-control mb-2" rows="3" disabled data-bind="value: $root.selectedLicenseItem().licenseValue"></textarea>
                                <!--end::Input-->
                                <!--end::Input group-->
                            </div>

                            <!--begin::Input group-->
                            <div class="mb-5 fv-row fv-plugins-icon-container">
                                <!--begin::Label-->
                                <label class="required form-label">Từ ngày</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input class="form-control"
                                       type="text"
                                       data-bind="flatpickrDateTime: $root.selectedLicenseItem().createdTime" />
                                <!--end::Input-->
                                <!--end::Input group-->
                            </div>
                            <!--begin::Input group-->
                            <div class="mb-5 fv-row fv-plugins-icon-container">
                                <!--begin::Label-->
                                <label class="required form-label">Đến ngày</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input class="form-control"
                                       type="text"
                                       data-bind="flatpickrDateTime: $root.selectedLicenseItem().expiredTime"/>

                                <!--end::Input-->
                                <!--end::Input group-->
                            </div>

                        </div>

                        <!--end::General options-->
                    </div>
                    <!-- /ko -->

                </div>

            </div>
            <!--end::Main column-->
        </form>
        <!--end::Form-->
    </div>
</div>

<!--begin::Modal - Add task-->
<div class="modal fade" id="kt_modal_add_license" tabindex="-1" aria-hidden="true">
    <!--begin::Modal dialog-->
    <div class="modal-dialog modal-dialog-centered mw-650px">
        <!--begin::Modal content-->
        <div class="modal-content">
            <!--begin::Modal header-->
            <div class="modal-header">
                <!--begin::Modal title-->
                <h2 class="fw-bold">Gán License</h2>
                <!--end::Modal title-->
                <!--begin::Close-->
                <button type="button" class="btn btn-icon btn-sm" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-outline ki-cross fs-1"></i>
                </button>
                <!--end::Close-->
            </div>
            <!--end::Modal header-->
            <!--begin::Modal body-->
            <div class="modal-body px-5 my-7">
                <!--begin::Form-->
                <form class="form fv-plugins-bootstrap5 fv-plugins-framework" action="#">
                    <!--begin::Scroll-->
                    <div class="d-flex flex-column scroll-y px-5 px-lg-10">
                        <!--begin::Input group-->
                        <div class="fv-row mb-7 fv-plugins-icon-container">
                            <!--begin::Label-->
                            <label class="required fw-semibold fs-6 mb-2">Tên license</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="text" data-bind="value: $root.selectedLicenseItem().licenseName" class="form-control form-control-solid mb-3 mb-lg-0">
                            <!--end::Input-->
                            <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"></div>
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->

                        <div class="row g-3">
                            <div class="col">
                                <label class="form-label">Từ ngày</label>
                                <input type="date" class="form-control" data-bind="value:  $root.selectedLicenseItem().createdTime,attr: { min: new Date().toISOString().split('T')[0]}">
                            </div>
                            <div class="col">
                                <label class="form-label">Đến ngày</label>
                                <input type="date" class="form-control" data-bind="value:  $root.selectedLicenseItem().expiredTime, attr: { min: new Date().toISOString().split('T')[0]}">
                            </div>
                        </div>
                        @* <input id="startDate" class="form-control form-control-solid">
						<input id="endDate" class="form-control form-control-solid"> *@
                        <!--end::Input group-->
                    </div>
                    <!--end::Scroll-->
                    <!--begin::Actions-->
                    <div class="text-center pt-10">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="button" class="btn btn-primary" data-bind="click: $root.AttachedLicense">
                            Lưu
                        </button>
                    </div>
                    <!--end::Actions-->
                </form>
                <!--end::Form-->
            </div>
            <!--end::Modal body-->
        </div>
        <!--end::Modal content-->
    </div>
    <!--end::Modal dialog-->
</div>
<!--end::Modal - Add task-->

@section scripts {
    <script src="~/js/helpers/helpers.js?@(DateTime.Now.Ticks)"></script>
    <script src="~/js/Device/Detail.js?@(DateTime.Now.Ticks)"></script>

    <script type="text/javascript">
        $(document).ready(function () {

             ko.bindingHandlers.flatpickrDateTime = {
            init: function (element, valueAccessor, allBindings, viewModel, bindingContext) {
                const observable = valueAccessor();
                let flatpickrInstance;

                function initFlatpickr() {
                    flatpickrInstance = $(element).flatpickr({
                        enableTime: false,
                        enableSeconds: false,
                        dateFormat: "d/m/Y",
                        time_24hr: true,
                        locale: {
                            weekdays: {
                                shorthand: ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'],
                                longhand: ['Chủ Nhật', 'Thứ Hai', 'Thứ Ba', 'Thứ Tư', 'Thứ Năm', 'Thứ Sáu', 'Thứ Bảy']
                            },
                            months: {
                                shorthand: ['Th1', 'Th2', 'Th3', 'Th4', 'Th5', 'Th6', 'Th7', 'Th8', 'Th9', 'Th10', 'Th11', 'Th12'],
                                longhand: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12']
                            },
                            rangeSeparator: ' đến ',
                            weekAbbreviation: 'Tuần',
                            scrollTitle: 'Cuộn để tăng/giảm',
                            toggleTitle: 'Click để đổi',
                            amPM: ['SA', 'CH']
                        },

                        onOpen: function (selectedDates, dateStr, instance) {
                            instance.setDate(observable(), true);
                        },

                        onClose: function (selectedDates, dateStr, instance) {
                            observable(dateStr);
                        }
                    });
                }

                initFlatpickr();

                ko.utils.domNodeDisposal.addDisposeCallback(element, function () {
                    if (flatpickrInstance) {
                        flatpickrInstance.destroy();
                    }
                });
            },

            update: function (element, valueAccessor) {
                const value = ko.unwrap(valueAccessor());
                $(element).val(value);
            }
        };

            var helpers = new Helpers();
            var detailDeviceViewModel = new DetailDeviceViewModel(@ViewBag.DeviceId,helpers);
            detailDeviceViewModel.OnInit();
            ko.applyBindings(detailDeviceViewModel);
        });
    </script>
}