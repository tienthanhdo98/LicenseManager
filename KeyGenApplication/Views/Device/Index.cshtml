@section scripts {
    <script src="~/js/helpers/helpers.js?@(DateTime.Now.Ticks)"></script>
    <script src="~/js/Device/Index.js?@(DateTime.Now.Ticks)"></script>

    <script type="text/javascript">
        window.typeList = @Html.Raw(JsonSerializer.Serialize(statusTypeList));
        $(document).ready(function () {

              ko.bindingHandlers.flatpickrDateTime = {
            init: function (element, valueAccessor, allBindings, viewModel, bindingContext) {
                const observable = valueAccessor();
                let flatpickrInstance;

                function initFlatpickr() {
                    flatpickrInstance = $(element).flatpickr({
                        enableTime: false,
                        enableSeconds: false,
                        dateFormat: "d/m/Y",
                        time_24hr: true,
                        locale: {
                            weekdays: {
                                shorthand: ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'],
                                longhand: ['Chủ Nhật', 'Thứ Hai', 'Thứ Ba', 'Thứ Tư', 'Thứ Năm', 'Thứ Sáu', 'Thứ Bảy']
                            },
                            months: {
                                shorthand: ['Th1', 'Th2', 'Th3', 'Th4', 'Th5', 'Th6', 'Th7', 'Th8', 'Th9', 'Th10', 'Th11', 'Th12'],
                                longhand: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12']
                            },
                            rangeSeparator: ' đến ',
                            weekAbbreviation: 'Tuần',
                            scrollTitle: 'Cuộn để tăng/giảm',
                            toggleTitle: 'Click để đổi',
                            amPM: ['SA', 'CH']
                        },

                        onOpen: function (selectedDates, dateStr, instance) {
                            instance.setDate(observable(), true);
                        },

                        onClose: function (selectedDates, dateStr, instance) {
                            observable(dateStr);
                        }
                    });
                }

                initFlatpickr();

                ko.utils.domNodeDisposal.addDisposeCallback(element, function () {
                    if (flatpickrInstance) {
                        flatpickrInstance.destroy();
                    }
                });
            },

            update: function (element, valueAccessor) {
                const value = ko.unwrap(valueAccessor());
                $(element).val(value);
            }
        };

            var helpers = new Helpers();
            var deviceViewModel = new DeviceViewModel(helpers);
            deviceViewModel.OnInit();
            ko.applyBindings(deviceViewModel);
        });
    </script>
}