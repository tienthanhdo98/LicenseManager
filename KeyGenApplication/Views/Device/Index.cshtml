@using System.Text.Json
@{
    var statusTypeList = ((IEnumerable<SelectListItem>)ViewBag.StatusSelects)
        .Select(x => new { id = int.Parse(x.Value), name = x.Text });
}
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section ToolBar {
    <div class="toolbar py-2" id="kt_toolbar">
        <!--begin::Container-->
        <div id="kt_toolbar_container" class=" container-fluid  d-flex align-items-center">
            <div data-kt-swapper="true" data-kt-swapper-mode="prepend" data-kt-swapper-parent="{default: '#kt_content_container', 'lg': '#kt_toolbar_container'}" class="page-title d-flex align-items-center flex-wrap me-3  mb-5 mb-lg-0 ">
                <!--begin::Title-->
                <h1 class="d-flex align-items-center text-dark fw-bold my-1 fs-3">
                    Quản lý Thiết bị
                </h1>
                <!--end::Title-->
                <!--begin::Separator-->
                <span class="h-20px border-gray-200 border-start mx-3"></span>
                <!--end::Separator-->
                <!--begin::Breadcrumb-->
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                    <!--begin::Item-->
                    <li class="breadcrumb-item text-muted">
                        <a href="/" class="text-muted text-hover-primary">
                            Trang chủ
                        </a>
                    </li>
                    <!--end::Item-->
                    <!--begin::Item-->
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-200 w-5px h-2px"></span>
                    </li>
                    <!--end::Item-->
                    <!--begin::Item-->
                    <li class="breadcrumb-item ">
                        Thiết bị
                    </li>
                    <!--end::Item-->
                    <!--begin::Item-->
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-200 w-5px h-2px"></span>
                    </li>
                    <!--end::Item-->
                </ul>
                <!--end::Breadcrumb-->
            </div>
            <!--begin::Page title-->
            <div class="flex-grow-1 flex-shrink-0 me-5">

                <!--begin::Page title-->
                <!--end::Page title-->
            </div>
            <!--end::Page title-->
            <!--begin::Action group-->

            <div class="d-flex align-items-center flex-wrap">
            </div>
            <!--end::Action group-->
        </div>
        <!--end::Container-->
    </div>
}

<div class="g-5 g-xl-10 ">
    <div class="card content d-flex flex-column flex-column-fluid" id="kt_content">
        <!--begin::Container-->
        <div id="kt_content_container" class="container-xxl">
            <!--begin::Card-->
            <div class="card">
                <!--begin::Card header-->
                <div class="card-header border-0 pt-6">
                    <!--begin::Card title-->
                    <div class="card-title">
                        <!--begin::Search-->
                        <div class="d-flex align-items-center position-relative my-1">
                            <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
                            <input type="text" data-kt-user-table-filter="search" class="form-control form-control-solid w-250px ps-13" placeholder="Tìm thiết bị" data-bind="value: $root.Filter.DeviceName, event: { change: $root.OnFilter }">
                        </div>
                        <div class="form-group d-none d-lg-block ms-2">
                            <select class="d-flex form-select w-200px form-select-solid"
                                    data-bind="
         select2: $root.Filter.Status,  /* Đổi 'value' thành 'select2' */
         options: $root.statusOptions,
         optionsText: 'name',
         optionsValue: 'id',
         optionsCaption: 'Trạng thái',
         event: { change: $root.OnFilter }
        ">
                            </select>
                        </div>
                        <!--end::Search-->
                    </div>
                    <!--begin::Card title-->
                    <!--begin::Card toolbar-->
                    <div class="card-toolbar">
                        <!--begin::Toolbar-->
                        <!--begin::Add user-->
                        <button type="button" class="btn btn-primary" data-bind="click: function(){ $root.OpenAddDeviceModal() }">
                            <i class="ki-outline ki-plus fs-2"></i>Thêm Device
                        </button>
                        <!--end::Add user-->
                    </div>
                    <!--end::Toolbar-->
                    <!--begin::Group actions-->
                    <div class="d-flex justify-content-end align-items-center d-none" data-kt-user-table-toolbar="selected">
                        <div class="fw-bold me-5">
                            <span class="me-2" data-kt-user-table-select="selected_count"></span>Selected
                        </div>
                        <button type="button" class="btn btn-danger" data-kt-user-table-select="delete_selected">Delete Selected</button>
                    </div>
                    <!--end::Group actions-->
                    <!--begin::Modal - Add task-->
                    <div class="modal fade" id="kt_modal_add_device" tabindex="-1" aria-hidden="true">
                        <!--begin::Modal dialog-->
                        <div class="modal-dialog modal-dialog-centered mw-650px">
                            <!--begin::Modal content-->
                            <div class="modal-content">
                                <!--begin::Modal header-->
                                <div class="modal-header" id="kt_modal_add_device_header">
                                    <!--begin::Modal title-->
                                    <h2 class="fw-bold">Thêm Device</h2>
                                    <!--end::Modal title-->
                                    <!--begin::Close-->
                                    <button type="button" class="btn btn-icon btn-sm" data-bs-dismiss="modal" aria-label="Close">
                                        <i class="ki-outline ki-cross fs-1"></i>
                                    </button>
                                    <!--end::Close-->
                                </div>
                                <!--end::Modal header-->
                                <!--begin::Modal body-->
                                <div class="modal-body px-5 my-7">
                                    <!--begin::Form-->
                                    <form class="form fv-plugins-bootstrap5 fv-plugins-framework" action="#">
                                        <!--begin::Scroll-->
                                        <div class="d-flex flex-column scroll-y px-5 px-lg-10">
                                            <!--begin::Input group-->
                                            <div class="fv-row mb-7 fv-plugins-icon-container">
                                                <!--begin::Label-->
                                                <label class="required fw-semibold fs-6 mb-2">Tên thiết bị</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input type="text" data-bind="value: $root.selecteDeviceItem().deviceName" class="form-control form-control-solid mb-3 mb-lg-0">
                                                <!--end::Input-->
                                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"></div>
                                            </div>
                                            <!--end::Input group-->
                                            <!--begin::Input group-->
                                            <div class="fv-row mb-7 fv-plugins-icon-container">
                                                <!--begin::Label-->
                                                <label class="required fw-semibold fs-6 mb-2">ChipsetID</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input data-bind="value: $root.selecteDeviceItem().chipsetID" class="form-control form-control-solid mb-3 mb-lg-0">
                                                <!--end::Input-->
                                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"></div>
                                            </div>
                                            <div class="fv-row mb-7 fv-plugins-icon-container">
                                                <!--begin::Label-->
                                                <label class="fw-semibold fs-6 mb-2">Ghi chú</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input data-bind="value: $root.selecteDeviceItem().note" class="form-control form-control-solid mb-3 mb-lg-0">
                                                <!--end::Input-->
                                                <div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"></div>
                                            </div>
                                            <!--end::Input group-->
                                        </div>
                                        <!--end::Scroll-->
                                        <!--begin::Actions-->
                                        <div class="text-center pt-10">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                            <button type="button" class="btn btn-primary" data-bind="click: $root.InsertDevice">
                                                Lưu
                                            </button>
                                        </div>
                                        <!--end::Actions-->
                                    </form>
                                    <!--end::Form-->
                                </div>
                                <!--end::Modal body-->
                            </div>
                            <!--end::Modal content-->
                        </div>
                        <!--end::Modal dialog-->
                    </div>
                    <!--end::Modal - Add task-->
                </div>
                <!--end::Card toolbar-->
            </div>
            <!--end::Card header-->
            <!--begin::Card body-->
            <div class="card-body py-4  px-10">
                <!--begin::Table-->
                <div id="kt_table_users_wrapper" class="dt-container dt-bootstrap5 dt-empty-footer">
                    <div id="" class="table-responsive">
                        <table class="table align-middle table-row-dashed fs-6 gy-5 dataTable" id="kt_table_users" style="width: 100%;">
                            <colgroup><col data-dt-column="0" style="width: 36.4px;"><col data-dt-column="1" style="width: 196.213px;"><col data-dt-column="2" style="width: 186.913px;"><col data-dt-column="3" style="width: 186.913px;"><col data-dt-column="4" style="width: 186.913px;"><col data-dt-column="5" style="width: 250.925px;"><col data-dt-column="6" style="width: 157.225px;"></colgroup>
                            <thead>
                                <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
                                    <th class="min-w-225px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Name</span></th>
                                    <th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">ChipsetID</span></th>
                                    <th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">License</span></th>
                                    <th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">License status</span></th>
                                    <th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Note</span></th>
                                    <th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Actions</span></th>
                                </tr>
                            </thead>
                            <tbody class="text-gray-600 fw-semibold" data-bind="foreach: $root.listDeviceItem">
                                <tr>
                                    @* , click: function(){ $root.clickDeviceItem($data, $index()); *@
                                    <td class="text-gray-800 mb-1">
                                        <a href="javascript:void(0)" class="text-hover-primary text-gray-800"
                                           style="cursor:pointer;"
                                           data-bind="text: deviceName, click: function(){ $root.clickDeviceItem($data, $index())}"></a>
                                    </td>
                                    <td data-bind="text: chipsetID">
                                    </td>
                                    <td class="license-cell">
                                        <!-- nếu có licenseValue -->
                                        <!-- ko if: licenseItem() && licenseItem().licenseValue && licenseItem().licenseValue() && licenseItem().licenseValue().trim() !== '' -->
                                        <span data-bind="
             text: licenseItem().licenseValue,
             attr: { 'data-bs-toggle': 'tooltip', title: licenseItem().licenseValue() }
           "></span>
                                        <!-- /ko -->
                                        <!-- nếu chưa có license -->
                                        <!-- ko ifnot: licenseItem() && licenseItem().licenseValue && licenseItem().licenseValue() && licenseItem().licenseValue().trim() !== '' -->
                                        <button type="button"
                                                class="btn btn-sm btn-primary"
                                                data-bind="click: function(){ $root.OpenAssignLicenseModal($data) }">
                                            Gán license
                                        </button>
                                        <!-- /ko -->
                                    </td>
                                    <td>
                                        <div class="badge fw-bold p-3"
                                             data-bind="text: $root.getLicenseStatusText(licenseItem()),
            css:  $root.getLicenseStatusClass(licenseItem())">
                                        </div>
                                    </td>
                                    <td>
                                        <div data-bind="text: note"></div>
                                    </td>
                                    <td>

                                        <a class="btn btn-secondary btn-sm copy-icon" data-bind="click: function(){ $root.CopyLicense($data,$index()) }">
                                            Copy
                                        </a>
                                        <a class="btn btn-primary btn-sm" data-bind="click: function(){ $root.OpenUpdateDeviceModal($data) }">
                                            Sửa
                                        </a>

                                        <a class="btn btn-danger btn-sm" data-bind="click: function(){ $root.DeleteDevice($data) }">
                                            Xóa
                                        </a>

                                    </td>
                                </tr>

                            </tbody>

                        </table>
                    </div>
                    <div class="d-flex mb-3 justify-content-md-end">

                        <ul role="button" data-bind="visible: $root.NeedPaging" class="pagination pagination-sm">

                            <li data-bind="disabled: !$root.PreviousPageActive()" class="page-item">
                                <a data-bind="click: $root.GoToPrevious" class="page-link"><i class="previous"></i></a>
                            </li>


                            <!-- ko foreach: $root.GetPages().slice(0, $root.PageIndex() + 5) -->
                            <li class="page-item" data-bind="class: $root.PageIndex() === $data ? 'active' : ''">
                                <a href="#" class="page-link" data-bind="click: $root.GoToPage, text: $data"></a>
                            </li>
                            <!-- /ko -->


                            <li data-bind="disabled: !$root.NextPageActive()" class="page-item">
                                <a data-bind="click: $root.GoToNext" class="page-link"><i class="next"></i></a>
                            </li>

                        </ul>


                    </div>
                </div>
                <!--end::Table-->
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Container-->
</div>
</div>

<!--begin::Modal - Add task-->
