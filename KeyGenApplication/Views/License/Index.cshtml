	<!--end::Modal dialog-->
</div>

@section scripts {
	<script src="~/js/helpers/helpers.js?@(DateTime.Now.Ticks)"></script>
	<script src="~/js/License/Index.js?@(DateTime.Now.Ticks)"></script>

	<script type="text/javascript">
		window.typeList = @Html.Raw(JsonSerializer.Serialize(statusTypeList));
		$(document).ready(function () {

					 ko.bindingHandlers.flatpickrDateTime = {
		  init: function (element, valueAccessor) {
			const observable = valueAccessor();
			let lastValid = ko.unwrap(observable) || ""; // lưu giá trị trước đó

			const fp = flatpickr(element, {
			  enableTime: false,
			  enableSeconds: false,
			  dateFormat: "d/m/Y",
			  time_24hr: true,
			  locale: {
				weekdays: {
				  shorthand: ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'],
				  longhand: ['Chủ Nhật', 'Thứ Hai', 'Thứ Ba', 'Thứ Tư', 'Thứ Năm', 'Thứ Sáu', 'Thứ Bảy']
				},
				months: {
				  shorthand: ['Th1', 'Th2', 'Th3', 'Th4', 'Th5', 'Th6', 'Th7', 'Th8', 'Th9', 'Th10', 'Th11', 'Th12'],
				  longhand: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12']
				},
				rangeSeparator: ' đến ',
				weekAbbreviation: 'Tuần',
				scrollTitle: 'Cuộn để tăng/giảm',
				toggleTitle: 'Click để đổi',
				amPM: ['SA', 'CH']
			  },

			  onOpen: function (_selectedDates, _dateStr, instance) {
				const v = ko.unwrap(observable) || lastValid;
				if (v) instance.setDate(v, true, instance.config.dateFormat);
			  },

			  onChange: function (_selectedDates, dateStr) {
				// chỉ cập nhật khi user chọn thật
				if (dateStr) {
				  lastValid = dateStr;
				  observable(dateStr);
				}
			  },

			  onClose: function (_selectedDates, dateStr, instance) {
				// đóng mà không chọn gì -> revert về giá trị trước đó, KHÔNG set observable = ""
				const current = ko.unwrap(observable) || "";
				if (!dateStr) {
				  const v = current || lastValid;
				  if (v) instance.setDate(v, true, instance.config.dateFormat);
				  return;
				}

				// có chọn thì đã update ở onChange rồi, nhưng để chắc:
				if (dateStr !== current) {
				  lastValid = dateStr;
				  observable(dateStr);
				}
			  }
			});

			// init lần đầu
			const initVal = ko.unwrap(observable);
			if (initVal) fp.setDate(initVal, true, fp.config.dateFormat);

			ko.utils.domNodeDisposal.addDisposeCallback(element, function () {
			  fp.destroy();
			});
		  },

		  update: function (element, valueAccessor) {
			const value = ko.unwrap(valueAccessor()) || "";
			const fp = element._flatpickr;

			if (fp) {
			  if (!value) fp.clear();
			  else fp.setDate(value, true, fp.config.dateFormat);
			}
		  }
		};


			var helpers = new Helpers();
			var licenseViewModel = new LicenseViewModel(helpers);
			licenseViewModel.OnInit();
			ko.applyBindings(licenseViewModel);
		});
	</script>
}