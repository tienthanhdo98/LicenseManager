													<!--end::Input-->
													<div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"></div>
												</div>
												<div class="fv-row mb-7 fv-plugins-icon-container">
													<!--begin::Label-->
													<label class="required fw-semibold fs-6 mb-2">Expires</label>
													<!--end::Label-->
													<!--begin::Input-->
													<input type="email" name="user_email" class="form-control form-control-solid mb-3 mb-lg-0" >
													<!--end::Input-->
													<div class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"></div>
												</div>
												<!--end::Input group-->
											</div>
											<!--end::Scroll-->
											<!--begin::Actions-->
											<div class="text-center pt-10">
												<button type="reset" class="btn btn-light me-3" data-kt-users-modal-action="cancel">Hủy</button>
