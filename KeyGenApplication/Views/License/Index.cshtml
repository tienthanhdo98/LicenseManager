													</span>
												</button>
											</div>
											<!--end::Actions-->
										</form>
										<!--end::Form-->
									</div>
									<!--end::Modal body-->
								</div>
								<!--end::Modal content-->
							</div>
							<!--end::Modal dialog-->
						</div>
						<!--end::Modal - Add task-->
					</div>
					<!--end::Card toolbar-->
				</div>
				<!--end::Card header-->
				<!--begin::Card body-->
				<div class="card-body py-4 px-10">
					<!--begin::Table-->
					<div id="kt_table_users_wrapper" class="dt-container dt-bootstrap5 dt-empty-footer">
						<div id="" class="table-responsive">
							<table class="table align-middle table-row-dashed fs-6 gy-5 dataTable" id="kt_table_users" style="width: 100%;">
								<colgroup><col data-dt-column="0" style="width: 36.4px;"><col data-dt-column="1" style="width: 196.213px;"><col data-dt-column="2" style="width: 186.913px;"><col data-dt-column="3" style="width: 186.913px;"><col data-dt-column="4" style="width: 186.913px;"><col data-dt-column="5" style="width: 250.925px;"><col data-dt-column="6" style="width: 157.225px;"></colgroup>
								<thead>
									<tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
										<th class="min-w-150px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Name</span></th>
										<th class="min-w-150px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Value</span></th>
										<th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Device</span></th>
										<th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Status</span></th>
										<th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Created</span></th>
										<th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Expires</span></th>
										<th class="min-w-125px" rowspan="1" colspan="1" tabindex="0"><span class="dt-column-title">Action</span></th>
									</tr>
								</thead>
								<tbody class="text-gray-600 fw-semibold" data-bind="foreach: $root.listLicenseItem">
									<tr>
										<td data-bind="text: licenseName" class="text-gray-800 text-hover-primary mb-1"></td>
										<td data-bind="text: licenseValue" class="mw-250px text-truncate"></td>
										<td data-bind="text: deviceName"></td>
										<td>
											<div data-bind="text: $root.getStatusName(status())" class="badge badge-light-success fw-bold p-3">Active</div>
										</td>
										<td data-bind="text: moment(createdTime()).format('DD/MM/YYYY')"></td>
										<td data-bind="text: moment(expiredTime()).format('DD/MM/YYYY')"></td>
