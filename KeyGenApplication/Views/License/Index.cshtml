							<i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
							<input type="text" data-kt-user-table-filter="search" class="form-control form-control-solid w-250px ps-13" placeholder="Tìm license" data-bind="value: $root.Filter.LicenseName , event: { change: $root.OnFilter }">
						</div>
						<!--end::Search-->
