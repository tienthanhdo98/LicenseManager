@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .custom-icon {
        margin-right: 5px;
        display: inline-flex;
        align-items: center;
    }
</style>
@section ToolBar {
<div class="toolbar py-2" id="kt_toolbar">
    <!--begin::Container-->
    <div id="kt_toolbar_container" class=" container-fluid  d-flex align-items-center">
        <div data-kt-swapper="true" data-kt-swapper-mode="prepend" data-kt-swapper-parent="{default: '#kt_content_container', 'lg': '#kt_toolbar_container'}" class="page-title d-flex align-items-center flex-wrap me-3  mb-5 mb-lg-0 ">
            <!--begin::Title-->
            <h1 class="d-flex align-items-center text-dark fw-bold my-1 fs-3">
                Quản trị menu
            </h1>
            <!--end::Title-->
            <!--begin::Separator-->
            <span class="h-20px border-gray-200 border-start mx-3"></span>
            <!--end::Separator-->
            <!--begin::Breadcrumb-->
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                <!--begin::Item-->
                <li class="breadcrumb-item text-muted">
                    <a href="/" class="text-muted text-hover-primary">
                        Trang chủ
                    </a>
                </li>
                <!--end::Item-->
                <!--begin::Item-->
                <li class="breadcrumb-item">
                    <span class="bullet bg-gray-200 w-5px h-2px"></span>
                </li>
                <!--end::Item-->
                <!--begin::Item-->
                <li class="breadcrumb-item text-dark">
                    Quản trị menu
                </li>
                <!--end::Item-->


            </ul>
            <!--end::Breadcrumb-->
        </div>
        <!--begin::Page title-->
        <div class="flex-grow-1 flex-shrink-0 me-5">

            <!--begin::Page title-->
            <!--end::Page title-->
        </div>
        <!--end::Page title-->
        <!--begin::Action group-->

        <div class="d-flex align-items-center flex-wrap">

        </div>
        <!--end::Action group-->
    </div>
    <!--end::Container-->
</div>
}

<div class="row g-5 g-xl-10">
    <!--begin::Col-->
    <div class="col-xl-6 mb-xl-10">

        <!--begin::List widget 20-->
        <div class="card h-xl-100">
            <!--begin::Header-->
            <div class="card-header border-left-1 pt-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-900">Menu</span>
                </h3>

                <!--begin::Toolbar-->
                <div class="card-toolbar">
                    <a href="#" class="btn btn-primary" onclick="menuViewModal.Add.show()">
                        <i class="fa fa-add"></i>
                        Thêm mới
                    </a>
                </div>
                <!--end::Toolbar-->
            </div>

            <div class="card-header d-flex justify-content-between align-items-center border-0 pt-5">
                <div class="d-flex align-items-center position-relative w-100">
                    <i class="ki-outline ki-magnifier fs-3 position-absolute ms-5"></i>
                    <input type="text" data-kt-user-table-filter="search" class="form-control form-control-solid ps-13" placeholder="Tìm kiếm" data-val="true" data-val-required="The Keyword field is required." id="search-input" name="Keyword" value="">
                </div>
            </div>
            <!--end::Header-->
            <!--begin::Body-->
            <div class="card-body pt-6">
                <div id="jstree-container">
                </div>
            </div>
            <!--end::Body-->
        </div>
        <!--end::List widget 20-->
    </div>
    <!--end::Col-->
    <!--begin::Col-->
    <div class="col-xl-6 mb-5 mb-xl-10">

        <!--begin::Timeline Widget 1-->
        <div class="card-flush h-xl-100">
            <div class="d-flex align-items-center mt-3 mb-6">
                <!--begin::Bullet-->
                <span data-kt-element="bullet" class="bullet bullet-vertical d-flex align-items-center min-h-20px mh-100 me-4 bg-info"></span>
                <!--end::Bullet-->
                <!--begin::Info-->
                <div class="flex-grow-1 me-5">
                    <h3 class="mb-0" id="title">Chưa có dữ liệu</h3>
                </div>
                <!--end::Info-->
                <!--begin::Action-->
                <div>
                    <a class="btn btn-primary" onclick="menuViewModal.Update.submit()">
                        <span class="indicator-label">
                            <i class="fa fa-sync-alt"></i>
                            Cập nhật
                        </span>
                        <span class="indicator-progress">
                            Vui lòng chờ... <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                        </span>
                    </a>
                    <a class="btn btn-danger" data-bind="click: $root.delete" onclick="menuViewModal.Delete()">
                        <i class="fa fa-close"></i>
                        Xóa
                    </a>
                </div>
                <!--end::Action-->
            </div>
            <div class="card">
                <form role="form" id="action" class="form fv-plugins-bootstrap5 fv-plugins-framework" asp-antiforgery="true" method="post" action="/Menus/Action">
                    <input name="id" class="form-control" type="hidden" />
                    <div class="card-body">
                        <input hidden name="applicationId" value="1" />
                        <div class="fv-row mb-7 fv-plugins-icon-container">
                            <!--begin::Label-->
                            <label class="d-flex align-items-center fs-6 fw-semibold mb-2">
                                <span class="">Chọn danh mục cha</span>
                            </label>
                            <!--end::Label-->
                            <div class="col-lg-12 fv-row">
                                <select data-placeholder="Chọn một tùy chọn" class="form-select form-select-solid" name="parentId">
                                    <option></option>
                                </select>
                            </div>
                        </div>

                        <div class="fv-row mb-7 fv-plugins-icon-container">
                            <!--begin::Label-->
                            <label class="d-flex align-items-center fs-6 fw-semibold mb-2">
                                <span class="required">Tiêu đề</span>
                                <span class="ms-1 cs-tooltip position-relative" aria-label="Trường này không được để trống" data-kt-initialized="1">
                                    <i class="ki-outline ki-information-5 text-gray-500 fs-6"></i>
                                </span>
                            </label>
                            <!--end::Label-->
                            <div class="col-lg-12 fv-row">
                                <input name="name" class="form-control form-control-lg form-control-solid" placeholder="Tiêu đề">
                            </div>
                        </div>

                        <div class="fv-row mb-7 fv-plugins-icon-container">
                            <!--begin::Label-->
                            <label class="d-flex align-items-center fs-6 fw-semibold mb-2">
                                <span class="required">Đường dẫn</span>
                                <span class="ms-1 cs-tooltip position-relative" aria-label="Trường này không được để trống" data-kt-initialized="1">
                                    <i class="ki-outline ki-information-5 text-gray-500 fs-6"></i>
                                </span>
                            </label>
                            <!--end::Label-->
                            <div class="col-lg-12 fv-row">
                                <input name="path" class="form-control form-control-lg form-control-solid" placeholder="Nhập đường dẫn">
                            </div>
                        </div>
                        <div class="fv-row mb-7 fv-plugins-icon-container">
                            <!--begin::Label-->
                            <label class="d-flex align-items-center fs-6 fw-semibold mb-2">
                                <span class="required">Icon</span>
                                <span class="ms-1 cs-tooltip position-relative" aria-label="Trường này không được để trống" data-kt-initialized="1">
                                    <i class="ki-outline ki-information-5 text-gray-500 fs-6"></i>
                                </span>
                            </label>
                            <!--end::Label-->
                            <div class="col-lg-12 fv-row">
                                <select data-placeholder="Chọn một tùy chọn" class="form-control form-control-solid selec2-icon" name="icon">
                                </select>
                            </div>
                        </div>

                        <div class="fv-row mb-7 fv-plugins-icon-container">
                            <!--begin::Label-->
                            <label class="d-flex align-items-center fs-6 fw-semibold mb-2">
                                <span class="required">Thứ tự</span>
                            </label>
                            <!--end::Label-->
                            <div class="col-lg-12 fv-row">
                                <input name="order" class="form-control form-control-lg form-control-solid" placeholder="Thứ tự">
                            </div>
                        </div>
                        <div class="fv-row mb-7 fv-plugins-icon-container">
                            <!--begin::Label-->
                            <label class="d-flex align-items-center fs-6 fw-semibold mb-2">
                                <span class="required">Hoạt động</span>
                            </label>
                            <!--end::Label-->
                            <div class="col-lg-8 d-flex align-items-center">
                                <div class="form-check form-check-solid form-switch form-check-custom fv-row">
                                    <input class="form-check-input w-45px h-30px" type="checkbox" name="isActive">
                                    <label class="form-check-label" for="status"></label>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <!--end::Timeline Widget 1-->
    </div>
    <!--end::Col-->
</div>

@section Scripts {
<script src="~/js/Menu/Index.js?@(DateTime.Now.Ticks)" type="text/javascript"></script>
<script src="~/js/helpers/AjaxHelpers.js?@(DateTime.Now.Ticks)"></script>
<script src="~/js/helpers/TreeHelper.js?@(DateTime.Now.Ticks)"></script>
<script src="~/js/helpers/FormHelpers.js?@(DateTime.Now.Ticks)"></script>
<script src="~/js/helpers/SelectIconHelper.js?@(DateTime.Now.Ticks)"></script>
<script src="~/js/helpers/helpers.js"></script>
<script src="~/js/helpers/ToastHelper.js"></script>

}